{
  "name": "leanquill",
  "displayName": "LeanQuill",
  "description": "LeanPub-style authoring assistant for VS Code with strict manuscript safety boundaries.",
  "version": "0.0.1",
  "publisher": "leanquill",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:leanquill.initialize",
    "onCommand:leanquill.updateChapterStatus",
    "onCommand:leanquill.openPlanningWorkspace",
    "onCommand:leanquill.createOutline",
    "onView:leanquill.chapters",
    "onView:leanquill.chapterContext",
    "onView:leanquill.outlineTree",
    "workspaceContains:Book.txt",
    "workspaceContains:manuscript"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "leanquill.initialize",
        "title": "LeanQuill: Initialize"
      },
      {
        "command": "leanquill.updateChapterStatus",
        "title": "Update Status",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.openPlanningWorkspace",
        "title": "LeanQuill: Open Planning Workspace"
      },
      {
        "command": "leanquill.createOutline",
        "title": "LeanQuill: Create Outline"
      },
      {
        "command": "leanquill.openBeatInEditor",
        "title": "Open Beat in Editor",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.addOutlinePart",
        "title": "Add Part",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.addOutlineChapter",
        "title": "Add Chapter",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.addOutlineBeat",
        "title": "Add Beat",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.removeOutlineNode",
        "title": "Remove",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.toggleOutlineActive",
        "title": "Toggle Active/Inactive",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.renameOutlineNode",
        "title": "Rename",
        "category": "LeanQuill"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "leanquill",
          "title": "LeanQuill",
          "icon": "media/leanquill.svg"
        }
      ]
    },
    "views": {
      "leanquill": [
        {
          "id": "leanquill.actions",
          "name": "Setup"
        },
        {
          "id": "leanquill.chapters",
          "name": "Chapters",
          "type": "tree",
          "when": "leanquill.isInitialized"
        },
        {
          "id": "leanquill.outlineTree",
          "name": "Outline",
          "type": "tree",
          "when": "leanquill.isInitialized"
        },
        {
          "id": "leanquill.chapterContext",
          "name": "Context",
          "type": "webview",
          "when": "leanquill.isInitialized"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "leanquill.updateChapterStatus",
          "when": "view == leanquill.chapters",
          "group": "leanquill@1"
        },
        {
          "command": "leanquill.addOutlineChapter",
          "when": "view == leanquill.outlineTree && viewItem =~ /outlinePart/",
          "group": "leanquill@1"
        },
        {
          "command": "leanquill.addOutlineBeat",
          "when": "view == leanquill.outlineTree && viewItem =~ /outlineChapter/",
          "group": "leanquill@1"
        },
        {
          "command": "leanquill.removeOutlineNode",
          "when": "view == leanquill.outlineTree",
          "group": "leanquill@2"
        },
        {
          "command": "leanquill.toggleOutlineActive",
          "when": "view == leanquill.outlineTree",
          "group": "leanquill@2"
        },
        {
          "command": "leanquill.renameOutlineNode",
          "when": "view == leanquill.outlineTree",
          "group": "leanquill@3"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "leanquill.actions",
        "contents": "Welcome to LeanQuill — your LeanPub-style authoring assistant.\n\nLeanQuill keeps your manuscript safe with strict write boundaries while helping you organize chapters, track characters, and manage your writing project.\n\n[Initialize Repository](command:leanquill.initialize)\n\nOpen a workspace containing your manuscript folder or Book.txt to get started.",
        "when": "!leanquill.hasManuscriptMarkers && !leanquill.isInitialized"
      },
      {
        "view": "leanquill.actions",
        "contents": "Welcome to LeanQuill — your LeanPub-style authoring assistant.\n\nLeanQuill keeps your manuscript safe with strict write boundaries while helping you organize chapters, track characters, and manage your writing project.\n\n[Initialize Repository](command:leanquill.initialize)\n\nManuscript markers detected — initialize to start managing your project with LeanQuill.",
        "when": "leanquill.hasManuscriptMarkers && !leanquill.isInitialized"
      },
      {
        "view": "leanquill.actions",
        "contents": "Welcome to LeanQuill — your LeanPub-style authoring assistant.\n\nLeanQuill keeps your manuscript safe with strict write boundaries while helping you organize chapters, track characters, and manage your writing project.\n\nThis project is initialized and ready to use.\n\n[Re-initialize](command:leanquill.initialize)",
        "when": "leanquill.isInitialized"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=dist/extension.js",
    "watch": "npm run build -- --watch",
    "test": "node --test dist-test/**/*.test.js",
    "build:test": "esbuild test/*.test.ts --bundle --platform=node --outdir=dist-test --format=cjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3"
  }
}
