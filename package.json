{
  "name": "leanquill",
  "displayName": "LeanQuill",
  "description": "LeanPub-style authoring assistant for VS Code with strict manuscript safety boundaries.",
  "version": "0.0.1",
  "publisher": "leanquill",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:leanquill.initialize",
    "onCommand:leanquill.openPlanningWorkspace",
    "onCommand:leanquill.createOutline",
    "onView:leanquill.outlineTree",
    "onView:leanquill.chapterContext",
    "onView:leanquill.research",
    "onView:leanquill.characters",
    "workspaceContains:manuscript/Book.txt",
    "workspaceContains:manuscript"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "leanquill.initialize",
        "title": "LeanQuill: Initialize"
      },
      {
        "command": "leanquill.updateNodeStatus",
        "title": "Update Status",
        "category": "LeanQuill",
        "icon": "$(symbol-event)"
      },
      {
        "command": "leanquill.addOrphanToOutline",
        "title": "Add to Outline",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.openPlanningWorkspace",
        "title": "Open Planning Workspace",
        "category": "LeanQuill",
        "icon": "$(preview)"
      },
      {
        "command": "leanquill.createOutline",
        "title": "Create Outline",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.openNodeInEditor",
        "title": "Open in Editor",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.addChildNode",
        "title": "Add Child",
        "category": "LeanQuill",
        "icon": "$(add)"
      },
      {
        "command": "leanquill.addSiblingNode",
        "title": "Add Sibling",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.removeOutlineNode",
        "title": "Remove",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.toggleOutlineActive",
        "title": "Toggle Active/Inactive",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.renameOutlineNode",
        "title": "Rename",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.openBookTxt",
        "title": "Open Book.txt",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.openChapterFromOutline",
        "title": "Open File",
        "category": "LeanQuill"
      },
      {
        "command": "leanquill.moveNodeUp",
        "title": "Move Up",
        "category": "LeanQuill",
        "icon": "$(arrow-up)"
      },
      {
        "command": "leanquill.moveNodeDown",
        "title": "Move Down",
        "category": "LeanQuill",
        "icon": "$(arrow-down)"
      },
      {
        "command": "leanquill.startResearch",
        "title": "New Research",
        "category": "LeanQuill",
        "icon": "$(add)"
      },
      {
        "command": "leanquill.newCharacter",
        "title": "New Character",
        "category": "LeanQuill",
        "icon": "$(person-add)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "leanquill",
          "title": "LeanQuill",
          "icon": "media/leanquill.svg"
        }
      ]
    },
    "views": {
      "leanquill": [
        {
          "id": "leanquill.actions",
          "name": "Setup"
        },
        {
          "id": "leanquill.outlineTree",
          "name": "Outline",
          "type": "webview"
        },
        {
          "id": "leanquill.chapterContext",
          "name": "Context",
          "type": "webview",
          "when": "leanquill.workspaceLeanQuillReady"
        },
        {
          "id": "leanquill.research",
          "name": "Research",
          "when": "leanquill.workspaceLeanQuillReady"
        },
        {
          "id": "leanquill.characters",
          "name": "Characters",
          "when": "leanquill.workspaceLeanQuillReady"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "leanquill.openPlanningWorkspace",
          "when": "view == leanquill.outlineTree && leanquill.workspaceLeanQuillReady",
          "group": "navigation@1"
        },
        {
          "command": "leanquill.addChildNode",
          "when": "view == leanquill.outlineTree && leanquill.workspaceLeanQuillReady",
          "group": "navigation@2"
        },
        {
          "command": "leanquill.startResearch",
          "when": "view == leanquill.research",
          "group": "navigation"
        },
        {
          "command": "leanquill.newCharacter",
          "when": "view == leanquill.characters",
          "group": "navigation"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "leanquill.actions",
        "contents": "Welcome to LeanQuill \u2014 your LeanPub-style authoring assistant.\n\nLeanQuill works in any folder: add a LeanPub-style `manuscript/` tree (including `manuscript/Book.txt`) or let Initialize create it.\n\n[Initialize Repository](command:leanquill.initialize)\n\nOpen a folder in VS Code, then initialize when you are ready.",
        "when": "leanquill.setupNeedsAttention && !leanquill.hasManuscriptMarkers"
      },
      {
        "view": "leanquill.actions",
        "contents": "Welcome to LeanQuill \u2014 your LeanPub-style authoring assistant.\n\nLeanQuill detected manuscript files or folders. [Initialize or complete setup](command:leanquill.initialize) to finish `project.yaml` and `manuscript/Book.txt` under `manuscript/` if anything is still missing.",
        "when": "leanquill.setupNeedsAttention && leanquill.hasManuscriptMarkers"
      },
      {
        "view": "leanquill.actions",
        "contents": "Welcome to LeanQuill \u2014 your LeanPub-style authoring assistant.\n\nLeanQuill keeps your manuscript safe with strict write boundaries while helping you organize chapters, track characters, and manage your writing project.\n\nThis workspace has a valid LeanQuill project and manuscript layout.\n\n[Re-initialize](command:leanquill.initialize)",
        "when": "leanquill.workspaceLeanQuillReady"
      },
      {
        "view": "leanquill.outlineTree",
        "contents": "LeanQuill setup is not complete yet.\n\nUse the Setup view to [initialize or finish manuscript layout](command:leanquill.initialize).",
        "when": "!leanquill.workspaceLeanQuillReady"
      },
      {
        "view": "leanquill.outlineTree",
        "contents": "No outline yet. Create one from your existing chapters.\n\n[Create Outline](command:leanquill.createOutline)",
        "when": "leanquill.workspaceLeanQuillReady"
      },
      {
        "view": "leanquill.research",
        "contents": "No research documents yet.\n\nUse the + button above to start your first research query, or ask your AI assistant to run the LeanQuill research workflow.",
        "when": "leanquill.workspaceLeanQuillReady"
      },
      {
        "view": "leanquill.characters",
        "contents": "No characters yet.\n\nUse the + button above to create your first character profile.",
        "when": "leanquill.workspaceLeanQuillReady"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=dist/extension.js",
    "watch": "npm run build -- --watch",
    "test": "node --test dist-test/**/*.test.js",
    "build:test": "esbuild test/*.test.ts --bundle --platform=node --outdir=dist-test --format=cjs"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3"
  }
}
